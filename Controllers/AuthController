using Microsoft.AspNetCore.Mvc;
using MySql.Data.MySqlClient;
using BarcTradeAPI.Models;
using BCrypt.Net;

namespace BarcTradeAPI.Controllers
{
    [ApiController]
[Route("api/[controller]")]
public class AuthController : ControllerBase
{
    private readonly IConfiguration _config;
    private readonly string _connectionString;

    public AuthController(IConfiguration config)
    {
        _config = config;
        _connectionString = _config.GetConnectionString("Default")!;
    }

    // Endpoint para realizar o login
    [HttpPost("login")]  // Aqui você define a rota específica para login
    public IActionResult Login([FromBody] LoginModel loginModel)
    {
        if (loginModel == null || string.IsNullOrEmpty(loginModel.Email) || string.IsNullOrEmpty(loginModel.Password))
        {
            return BadRequest(new { message = "Email e senha são obrigatórios" });
        }

        using var conn = new MySqlConnection(_connectionString);
        conn.Open();

        // Consulta o banco de dados apenas pelo email
        var cmd = new MySqlCommand("SELECT * FROM Usera WHERE email = @em", conn);
        cmd.Parameters.AddWithValue("@em", loginModel.Email);

        using var reader = cmd.ExecuteReader();

        if (reader.Read())
        {
            // Verifica se a senha fornecida corresponde ao hash armazenado
            var storedHash = reader.GetString("password");
            if (BCrypt.Net.BCrypt.Verify(loginModel.Password, storedHash)) // Usando o BCrypt para verificar
            {
                // Retorna a resposta com sucesso e os dados do usuário
                return Ok(new
                {
                    message = "Login efetuado com sucesso!",
                    id = reader.GetInt32("user_id"),
                    name = reader.GetString("name"),
                    email = reader.GetString("email")
                });
            }
            else
            {
                // Se a senha não corresponder
                return Unauthorized(new { message = "Credenciais inválidas." });
            }
        }

        // Caso o email não seja encontrado
        return Unauthorized(new { message = "Credenciais inválidas." });
    }
}
    // Modelo de dados para o login
    public class LoginModel
    {
        public string Email { get; set; }  // Email do usuário
        public string Password { get; set; }  // Senha do usuário
    }
}